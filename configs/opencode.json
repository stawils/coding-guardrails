# OpenCode configuration
# Point OpenCode at the coding-guardrails proxy.
#
# Usage:
#   1. Start llama-server on :8080
#   2. Start proxy: coding-guardrails serve --backend-url http://localhost:8080 --model <model> --port 8081
#   3. Copy this to ~/.config/opencode/opencode.json
#   4. Run: opencode

{
  "$schema": "https://opencode.ai/config.json",
  "model": "guardrails/qwen",
  "provider": {
    "guardrails": {
      "name": "Coding Guardrails",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:8081/v1",
        "apiKey": "not-needed"
      },
      "models": {
        "qwen": {
          "name": "Qwen3.5-9B-UD-Q4_K_XL",
          "_launch": true
        }
      }
    }
  }
}
