+/**
+ * Tolerant array check for freeform report fields (validationOutput,
+ * residualRisks, reviewFindings). Models frequently emit arrays of
+ * structured objects (e.g. validationOutput: [{test, result, summary}])
+ * rather than bare string[]. These fields are for human display, so any
+ * array shape is acceptable. (Root cause of F2: the strict isStringArray
+ * check rejected valid object-array reports, causing every otherwise-
+ * correct acceptance report to be discarded.)
+ */
+function isFlexibleArray(value: unknown): value is unknown[] {
+	return Array.isArray(value);
+}
