+/**
+ * Find the first `{` in `body`, then return the balanced JSON substring.
+ * Returns undefined if no balanced object exists.
+ */
+function extractFirstJsonObject(body: string): string | undefined {
+	const start = body.indexOf("{");
+	if (start === -1) return undefined;
+	return extractBalancedJson(body, start);
+}
