+ * Removes lines like "acceptance-report", "Here is my report:",
+ * "```", trailing/leading whitespace - anything before the first `{`.
+ */
+function stripLeadingNoise(body: string): string {
+	const start = body.indexOf("{");
+	if (start === -1) return body;
+	return body.slice(start);
