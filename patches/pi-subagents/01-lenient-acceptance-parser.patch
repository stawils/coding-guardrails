+/**
+ * Tolerant JSON.parse - strips trailing commas, JSONC comments, and
+ * single-line // comments before parsing.
+ */
+function tolerantJsonParse(text: string): unknown {
+	let cleaned = text;
+	// Strip /* ... */ block comments
+	cleaned = cleaned.replace(/\/\*[\s\S]*?\*\//g, "");
+	// Strip // line comments (only outside strings - best-effort)
+	cleaned = cleaned.replace(/^(\s*\/\/.*)$/gm, "");
+	// Strip trailing commas: ,] or ,} (with optional whitespace)
+	cleaned = cleaned.replace(/,(\s*[}\]])/g, "$1");
+	return JSON.parse(cleaned);
+}
+
+/**
+ * Try to parse `body` as JSON, then validate as an acceptance report.
+ * Accepts both top-level report objects and common wrappers:
+ *   - { "acceptance": {...} }              (legacy)
+ *   - { "acceptance-report": {...} }       (models sometimes use the fence tag as key)
+ * Returns undefined if parsing fails or the result isn't a valid report.
+ */
+function tryParseReport(body: string): AcceptanceReport | undefined {
+	const candidates: string[] = [];
+	const direct = extractFirstJsonObject(body);
+	if (direct) candidates.push(direct);
+	// Also try stripping leading prose like "acceptance-report\n{...}"
+	const stripped = extractFirstJsonObject(stripLeadingNoise(body));
+	if (stripped && stripped !== direct) candidates.push(stripped);
+
+	for (const candidate of candidates) {
+		try {
+			const parsed = tolerantJsonParse(candidate) as unknown;
+			if (parsed && typeof parsed === "object" && !Array.isArray(parsed)) {
+				const obj = parsed as Record<string, unknown>;
+				// Recognized wrapper keys — unwrap before validating
+				const wrapped = obj.acceptance ?? obj["acceptance-report"];
+				if (wrapped && typeof wrapped === "object") {
+					if (isAcceptanceReport(wrapped)) return wrapped;
+					continue; // wrapper present but inner shape invalid → don't fall through to outer check
+				}
+			}
+			if (isAcceptanceReport(parsed)) return parsed;
+		} catch {
+			// try next candidate
+		}
+	}
+	return undefined;
+}
+
+// ── Public API ──────────────────────────────────────────────────────────────
+
+export function parseAcceptanceReport(output: string): { report?: AcceptanceReport; error?: string } {
+	const errors: string[] = [];
+
+	// ── Strategy 1: classic `acceptance-report` fenced block ──
+	const classicFence = [...output.matchAll(/```acceptance-report\s*\n([\s\S]*?)```/gi)]
+		.map((m) => m[1]?.trim())
+		.filter((v): v is string => Boolean(v));
+	for (const body of classicFence) {
+		const report = tryParseReport(body);
+		if (report) return { report };
+		errors.push("acceptance-report fence: body did not parse as a valid report");
+	}
+
+	// ── Strategy 2: lenient fence - `json`, `jsonc`, `json5`, or plain ──
+	// Only accepts fenced JSON that LOOKS like a report (heuristic: must
+	// have at least one acceptance-report field) to avoid matching
+	// unrelated code blocks.
+	const lenientFence = [...output.matchAll(/```(?:jsonc?|json5)?\s*\n([\s\S]*?)```/gi)]
+		.map((m) => m[1]?.trim())
+		.filter((v): v is string => Boolean(v))
+		.filter((body) => /"(?:criteriaSatisfied|changedFiles|commandsRun|testsAddedOrUpdated|validationOutput|residualRisks|diffSummary|reviewFindings|manualNotes|notes|noStagedFiles|acceptance)"\s*:/.test(body));
+	for (const body of lenientFence) {
+		const report = tryParseReport(body);
+		if (report) return { report };
+		errors.push("lenient json fence: body looked like a report but did not parse");
+	}
+
+	// ── Strategy 3: ACCEPTANCE_REPORT: marker + balanced JSON ──
+	const markerMatch = output.match(/ACCEPTANCE_REPORT\s*:\s*/i);
+	if (markerMatch && markerMatch.index !== undefined) {
+		const after = output.slice(markerMatch.index + markerMatch[0].length);
+		const report = tryParseReport(after);
+		if (report) return { report };
+		errors.push("ACCEPTANCE_REPORT marker: JSON after marker did not parse");
+	}
+
+	// ── Strategy 4: last-resort - find any JSON object that parses as a report ──
+	// Scan the entire output for `{` and try each balanced object. This
+	// catches cases where the model emitted raw JSON with no fence at all.
+	const scanned: number[] = [];
+	for (let i = 0; i < output.length; i++) {
+		if (output[i] !== "{") continue;
+		// Skip if we already tried this position via strategy 1/2/3
+		if (scanned.includes(i)) continue;
+		const candidate = extractBalancedJson(output, i);
+		if (!candidate) continue;
+		try {
+			const parsed = tolerantJsonParse(candidate) as unknown;
+			if (parsed && typeof parsed === "object" && !Array.isArray(parsed)) {
+				const obj = parsed as Record<string, unknown>;
+				const wrapped = obj.acceptance ?? obj["acceptance-report"];
+				if (wrapped && typeof wrapped === "object" && isAcceptanceReport(wrapped)) return { report: wrapped as AcceptanceReport };
+			}
+			if (isAcceptanceReport(parsed)) return { report: parsed as AcceptanceReport };
+		} catch {
+			// not valid JSON at this position
+		}
+		scanned.push(i);
+	}
+
+	if (errors.length > 0) return { error: `Failed to parse acceptance-report: ${errors.join("; ")}` };
+	return { error: "Structured acceptance report not found." };
+}
+
+export function stripAcceptanceReport(output: string): string {
+	return output
+		.replace(/\n?```acceptance-report\s*\n[\s\S]*?```\s*$/i, "")
+		.replace(/\n?ACCEPTANCE_REPORT\s*:\s*\{[\s\S]*\}\s*$/i, "")
+		.trimEnd();
+}
